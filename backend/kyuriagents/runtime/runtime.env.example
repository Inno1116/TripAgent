DEEPAGENTS_TENANT_ID=default
DEEPAGENTS_USER_ID=local-user
DEEPAGENTS_THREAD_ID=local-thread

DASHSCOPE_API_KEY=replace-me
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
# Set false for DashScope thinking-capable models when tool calling or
# structured output is needed. Leave empty to omit the provider-specific flag.
DASHSCOPE_ENABLE_THINKING=false
# Optional cheaper model used only for short-term context summaries. Leave
# empty to reuse DASHSCOPE_CHAT_MODEL.
DEEPAGENTS_CONTEXT_SUMMARY_MODEL=
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
# Set this to the exact dimension you chose when creating the Milvus collection.
DASHSCOPE_EMBEDDING_DIMENSIONS=

DEEPAGENTS_POSTGRES_DATABASE=kyuriagents
DEEPAGENTS_POSTGRES_ADMIN_DSN=postgresql://postgres:replace-me@localhost:5432/postgres
DEEPAGENTS_POSTGRES_DSN=postgresql://kyuriagents:replace-me@localhost:5432/kyuriagents

DEEPAGENTS_ENABLE_RAG=true
DEEPAGENTS_ENABLE_MEMORY=true
DEEPAGENTS_ENABLE_CHECKPOINTER=true
DEEPAGENTS_ENABLE_TOOLS=true
DEEPAGENTS_ENABLE_TOOL_AUDIT=true
DEEPAGENTS_RAG_MODE=tool
DEEPAGENTS_MEMORY_MODE=hybrid

# Public web search. Start SearXNG locally on http://127.0.0.1:8888 before
# enabling this in local development.
DEEPAGENTS_ENABLE_SUBAGENTS=false
DEEPAGENTS_ENABLE_TASK_GRAPH_RUNTIME=true
DEEPAGENTS_ENABLE_WEB_SEARCH=false
SEARXNG_BASE_URL=http://127.0.0.1:8888
DEEPAGENTS_WEB_SEARCH_MAX_RESULTS=8
DEEPAGENTS_WEB_SEARCH_QUERY_PLAN_SIZE=3
DEEPAGENTS_WEB_SEARCH_CACHE_TTL_SECONDS=300
DEEPAGENTS_WEB_SEARCH_RERANK_CANDIDATES=24
DEEPAGENTS_WEB_AGENT_MAX_SEARCH_CALLS=3
DEEPAGENTS_WEB_SEARCH_SAFE_SEARCH=0
DEEPAGENTS_WEB_SEARCH_LANGUAGE=
DEEPAGENTS_WEB_SEARCH_FALLBACK_ENGINES=duckduckgo,bing,baidu,sogou
DEEPAGENTS_WEB_SEARCH_TIMEOUT_SECONDS=8
DEEPAGENTS_WEB_FETCH_MAX_PAGES=5
DEEPAGENTS_WEB_FETCH_CONCURRENCY=3
DEEPAGENTS_WEB_FETCH_RETRIES=1
DEEPAGENTS_WEB_FETCH_TIMEOUT_SECONDS=8
DEEPAGENTS_WEB_FETCH_MAX_BYTES=1000000
DEEPAGENTS_WEB_FETCH_MAX_CHARS=3000
DEEPAGENTS_WEB_RENDER_MAX_PAGES=3
DEEPAGENTS_WEB_RENDER_TIMEOUT_SECONDS=12

# Redis keeps in-flight turns outside the authoritative message table. A failed
# model/tool call will not leave a half-written chat turn in PostgreSQL.
DEEPAGENTS_REDIS_URL=redis://localhost:6379/0
DEEPAGENTS_PENDING_TURN_TTL_SECONDS=600
DEEPAGENTS_THREAD_LOCK_TTL_SECONDS=180

# Token and context window management. User inputs above
# KYURI_MAX_USER_INPUT_TOKENS are rejected before any chat messages are written.
# Older history is summarized when the approximate token trigger is reached;
# the model receives the summary plus the most recent messages.
KYURI_MAX_USER_INPUT_TOKENS=12800
KYURI_CONTEXT_WINDOW_TOKENS=128000
KYURI_RESERVED_OUTPUT_TOKENS=8192
KYURI_CONTEXT_SAFETY_RATIO=0.85
KYURI_MAX_RAG_CONTEXT_TOKENS=12000
KYURI_MAX_MEMORY_CONTEXT_TOKENS=3000
KYURI_MAX_TOOL_RESULT_TOKENS=6000
QWEN_TOKENIZER_MODEL=Qwen/Qwen3-8B
QWEN_TOKENIZER_LOCAL_FILES_ONLY=true
QWEN_TOKENIZER_STRICT=false
DEEPAGENTS_ENABLE_CONTEXT_SUMMARIZATION=true
DEEPAGENTS_CONTEXT_SUMMARY_TRIGGER_TOKENS=100000
DEEPAGENTS_CONTEXT_SUMMARY_TRIGGER_MESSAGES=0
DEEPAGENTS_CONTEXT_SUMMARY_KEEP_MESSAGES=12

# Default allows read/external-read/ordinary-write tools. Tools flagged as
# requiring confirmation are still blocked unless the setting below is true.
DEEPAGENTS_TOOL_ALLOWED_RISKS=read_only,external_read,write
DEEPAGENTS_TOOL_CONFIRMATION_RISKS=destructive,network
DEEPAGENTS_TOOL_ALLOW_REQUIRES_CONFIRMATION=false
DEEPAGENTS_TOOL_ALLOWED_NAMES=
DEEPAGENTS_TOOL_DENIED_NAMES=

DEEPAGENTS_ENABLE_MCP=false
DEEPAGENTS_MCP_CONFIG_PATH=
DEEPAGENTS_MCP_TOOL_NAME_PREFIX=false

# API server bootstrap. Admin endpoints are disabled when this is empty.
DEEPAGENTS_API_ADMIN_KEY=
DEEPAGENTS_API_HOST=127.0.0.1
DEEPAGENTS_API_PORT=8000
DEEPAGENTS_AUTH_TOKEN_TTL_DAYS=30
DEEPAGENTS_API_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

RAG_ES_URL=http://localhost:9200
RAG_ES_INDEX=rag_chunks
RAG_MILVUS_URI=http://localhost:19530
RAG_MILVUS_COLLECTION=rag_chunks
RAG_MILVUS_DB=
RAG_MILVUS_TOKEN=
RAG_KB_IDS=
# Set DEEPAGENTS_RAG_RERANK_MODEL=off to disable the DashScope rerank layer.
DEEPAGENTS_RAG_RERANK_MODEL=qwen3-vl-rerank
DEEPAGENTS_RAG_RERANK_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
DEEPAGENTS_RAG_RERANK_TIMEOUT_SECONDS=10

# User uploads and offline knowledge-base ingestion.
DEEPAGENTS_UPLOAD_DIR=.kyuriagents/uploads
DEEPAGENTS_UPLOAD_MAX_BYTES=26214400
DEEPAGENTS_INGESTION_PARSER=auto
DEEPAGENTS_INGESTION_MCP_CONFIG_PATH=
DEEPAGENTS_INGESTION_MCP_TOOL_NAME=parse_document
DEEPAGENTS_ENABLE_INGESTION_REDIS_QUEUE=true
DEEPAGENTS_INGESTION_REDIS_QUEUE_NAME=kyuri:ingestion:jobs
DEEPAGENTS_INGESTION_REDIS_BLOCK_TIMEOUT_SECONDS=2
DEEPAGENTS_INGESTION_CHUNK_CHARS=1200
DEEPAGENTS_INGESTION_CHUNK_OVERLAP=180
DEEPAGENTS_INGESTION_EMBEDDING_BATCH_SIZE=10
DEEPAGENTS_INGESTION_JOB_TIMEOUT_SECONDS=900

