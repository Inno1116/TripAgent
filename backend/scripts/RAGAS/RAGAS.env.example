# Copy this file to `RAGAS.env` for offline RAG / RAGAS evaluation.
# `RAGAS.env` is local-only and should not be committed.
#
# The evaluation scripts first load backend/runtime.env as a fallback, then load
# this file and override duplicate variables. Put evaluation-only model/key
# settings here to avoid affecting the running backend service.

# DashScope OpenAI-compatible chat model used by answer generation and RAGAS/LLM judge.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_ENABLE_THINKING=false

# Optional role-specific models. When empty, both roles use DASHSCOPE_CHAT_MODEL.
# Example: use a cheaper/free model for judge while keeping answer generation on
# the default model.
RAGAS_ANSWER_MODEL=
RAGAS_JUDGE_MODEL=

# Optional role-specific OpenAI-compatible endpoint for judge. Leave empty to
# reuse DASHSCOPE_API_KEY / DASHSCOPE_BASE_URL. For DeepSeek official API, set
# these and set RAGAS_JUDGE_MODEL to the DeepSeek model name you want.
RAGAS_JUDGE_API_KEY=
RAGAS_JUDGE_BASE_URL=
RAGAS_JUDGE_ENABLE_THINKING=

# Query embedding model. Keep this consistent with the indexed documents unless
# you intentionally rebuild/re-embed the evaluation knowledge base.
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSIONS=1024

# Rerank layer used by `--mode hybrid_rerank`.
DEEPAGENTS_RAG_RERANK_MODEL=qwen3-vl-rerank
DEEPAGENTS_RAG_RERANK_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
DEEPAGENTS_RAG_RERANK_TIMEOUT_SECONDS=30

# Retrieval backends. You can omit these if backend/runtime.env already points
# at the evaluation database/indexes.
DEEPAGENTS_POSTGRES_DSN=
RAG_ES_URL=http://localhost:9200
RAG_ES_INDEX=rag_chunks
RAG_MILVUS_URI=http://localhost:19530
RAG_MILVUS_COLLECTION=rag_chunks
RAG_MILVUS_DB=
RAG_MILVUS_TOKEN=
