# Compose interpolation values. Keep these passwords aligned with the DSNs below.
POSTGRES_DB=kyuriagents
POSTGRES_USER=kyuriagents
POSTGRES_PASSWORD=change-this-postgres-password
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
WEB_PORT=8080
API_PORT=8000
SEARXNG_PORT=8888
ES_PORT=9200
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
KYURIAGENTS_API_BASE=/api
KYURIAGENTS_INTERNAL_API_BASE=http://api:8000
KYURIAGENTS_REDIS_URL=redis://redis:6379/0

# Tenant defaults used by bootstrap scripts and local admin operations.
KYURIAGENTS_TENANT_ID=default
KYURIAGENTS_USER_ID=local-user
KYURIAGENTS_THREAD_ID=local-thread

# DashScope model settings.
DASHSCOPE_API_KEY=replace-me
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
KYURIAGENTS_CONTEXT_SUMMARY_MODEL=
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSIONS=1024

# PostgreSQL.
# Full-stack compose uses host `postgres`.
# External-services compose should replace host/user/password/database with your external PostgreSQL values.
KYURIAGENTS_POSTGRES_DATABASE=kyuriagents
KYURIAGENTS_POSTGRES_ADMIN_DSN=
KYURIAGENTS_POSTGRES_DSN=postgresql://kyuriagents:change-this-postgres-password@postgres:5432/kyuriagents

# Runtime features.
KYURIAGENTS_ENABLE_RAG=true
KYURIAGENTS_ENABLE_MEMORY=true
KYURIAGENTS_ENABLE_CHECKPOINTER=true
KYURIAGENTS_ENABLE_TOOLS=true
KYURIAGENTS_ENABLE_TOOL_AUDIT=true
KYURIAGENTS_RAG_MODE=tool
KYURIAGENTS_MEMORY_MODE=hybrid

# Web search.
# The full Docker compose stack includes SearXNG at host `searxng`.
KYURIAGENTS_ENABLE_WEB_SEARCH=true
SEARXNG_BASE_URL=http://searxng:8080
KYURIAGENTS_WEB_SEARCH_MAX_RESULTS=8
KYURIAGENTS_WEB_SEARCH_SAFE_SEARCH=0
KYURIAGENTS_WEB_SEARCH_LANGUAGE=
KYURIAGENTS_WEB_SEARCH_FALLBACK_ENGINES=duckduckgo,bing,baidu,sogou
KYURIAGENTS_WEB_SEARCH_TIMEOUT_SECONDS=8
KYURIAGENTS_WEB_FETCH_MAX_PAGES=5
KYURIAGENTS_WEB_FETCH_CONCURRENCY=3
KYURIAGENTS_WEB_FETCH_RETRIES=1
KYURIAGENTS_WEB_FETCH_TIMEOUT_SECONDS=8
KYURIAGENTS_WEB_FETCH_MAX_BYTES=1000000
KYURIAGENTS_WEB_FETCH_MAX_CHARS=6000
KYURIAGENTS_WEB_RENDER_MAX_PAGES=2
KYURIAGENTS_WEB_RENDER_TIMEOUT_SECONDS=12

# Short-term context summarization.
KYURIAGENTS_ENABLE_CONTEXT_SUMMARIZATION=true
KYURIAGENTS_CONTEXT_SUMMARY_TRIGGER_TOKENS=100000
KYURIAGENTS_CONTEXT_SUMMARY_TRIGGER_MESSAGES=0
KYURIAGENTS_CONTEXT_SUMMARY_KEEP_MESSAGES=12

# Request safety and context budgeting.
KYURIAGENTS_PENDING_TURN_TTL_SECONDS=600
KYURIAGENTS_THREAD_LOCK_TTL_SECONDS=180
KYURI_MAX_USER_INPUT_TOKENS=12800
KYURI_CONTEXT_WINDOW_TOKENS=128000
KYURI_RESERVED_OUTPUT_TOKENS=8192
KYURI_CONTEXT_SAFETY_RATIO=0.85
KYURI_MAX_RAG_CONTEXT_TOKENS=12000
KYURI_MAX_MEMORY_CONTEXT_TOKENS=3000
KYURI_MAX_TOOL_RESULT_TOKENS=6000
QWEN_TOKENIZER_MODEL=Qwen/Qwen3-8B
QWEN_TOKENIZER_LOCAL_FILES_ONLY=true
QWEN_TOKENIZER_STRICT=false

# Tool governance.
KYURIAGENTS_TOOL_ALLOWED_RISKS=read_only,external_read,write
KYURIAGENTS_TOOL_CONFIRMATION_RISKS=destructive,network
KYURIAGENTS_TOOL_ALLOW_REQUIRES_CONFIRMATION=false
KYURIAGENTS_TOOL_ALLOWED_NAMES=
KYURIAGENTS_TOOL_DENIED_NAMES=

# MCP.
KYURIAGENTS_ENABLE_MCP=false
KYURIAGENTS_MCP_CONFIG_PATH=
KYURIAGENTS_MCP_TOOL_NAME_PREFIX=false

# Document ingestion.
# local: parse text PDFs, DOCX, and TXT inside the worker.
# mcp: call a configured MCP parser.
# auto: use MCP when configured, otherwise local.
KYURIAGENTS_UPLOAD_DIR=/data/uploads
KYURIAGENTS_UPLOAD_MAX_BYTES=26214400
KYURIAGENTS_INGESTION_PARSER=auto
KYURIAGENTS_INGESTION_MCP_CONFIG_PATH=
KYURIAGENTS_INGESTION_MCP_TOOL_NAME=parse_document
KYURIAGENTS_ENABLE_INGESTION_REDIS_QUEUE=true
KYURIAGENTS_INGESTION_REDIS_QUEUE_NAME=kyuri:ingestion:jobs
KYURIAGENTS_INGESTION_REDIS_BLOCK_TIMEOUT_SECONDS=2
KYURIAGENTS_INGESTION_CHUNK_CHARS=1200
KYURIAGENTS_INGESTION_CHUNK_OVERLAP=180
KYURIAGENTS_INGESTION_EMBEDDING_BATCH_SIZE=10
KYURIAGENTS_INGESTION_JOB_TIMEOUT_SECONDS=900

# API server.
KYURIAGENTS_API_ADMIN_KEY=replace-this-admin-key
KYURIAGENTS_API_HOST=0.0.0.0
KYURIAGENTS_API_PORT=8000
KYURIAGENTS_AUTH_TOKEN_TTL_DAYS=30
KYURIAGENTS_API_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# RAG and memory indexes.
# Full-stack compose uses host `elasticsearch` and `milvus`.
# External-services compose should replace these with your external service addresses.
RAG_ES_URL=http://elasticsearch:9200
RAG_ES_INDEX=rag_chunks
RAG_MILVUS_URI=http://milvus:19530
RAG_MILVUS_COLLECTION=rag_chunks
RAG_MILVUS_DB=
RAG_MILVUS_TOKEN=
RAG_KB_IDS=

MEMORY_ES_INDEX=memory_chunks
MEMORY_MILVUS_COLLECTION=memory_chunks
